# Copy this to .env.local and fill in your keys. .env.local is gitignored.

# Anthropic — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Stripe (use TEST keys for dev — https://dashboard.stripe.com/test/apikeys)
# Secret key: server-side only (api/ functions). Do NOT add a VITE_ prefix.
STRIPE_SECRET_KEY=sk_test_...
# Publishable key: safe for the browser. VITE_ prefix exposes it to client code.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
